{
  "name": "fairvalue-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "FairValue Engine 프론트엔드(Next.js App Router). 스키마 구동 폼 렌더러 + CB 수직관통. 기존 계약 검증 스크립트(verify:bind/lint:openapi) 보존.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:bind": "tsx scripts/verify-bind.ts",
    "lint:openapi": "tsx scripts/lint-openapi.ts",
    "verify:all": "vitest run && tsx scripts/verify-bind.ts && tsx scripts/lint-openapi.ts"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@tanstack/react-query": "5.51.11",
    "react-hook-form": "7.52.1",
    "zod": "3.23.8",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "yaml": "^2.5.0"
  }
}
